{
  "consumer": {
    "name": "OrchestratorMS"
  },
  "interactions": [
    {
      "description": "a request for all microcontrollers for a user",
      "providerStates": [
        {
          "name": "microcontrollers exist"
        }
      ],
      "request": {
        "headers": {
          "x-internal-api-key": "testkey"
        },
        "method": "GET",
        "path": "/",
        "query": {
          "username": [
            "testuser"
          ]
        }
      },
      "response": {
        "body": [
          {
            "ip": "192.168.1.1",
            "measure": "humidity",
            "sensor": "DHT11",
            "username": "testuser"
          }
        ],
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].ip": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].measure": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].sensor": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to create a microcontroller",
      "providerStates": [
        {
          "name": "microcontroller does not exist"
        }
      ],
      "request": {
        "body": {
          "ip": "192.168.1.50",
          "measure": "temperature",
          "sensor": "DS18B20",
          "username": "testuser"
        },
        "headers": {
          "Content-Type": "application/json",
          "x-internal-api-key": "testkey"
        },
        "method": "POST",
        "path": "/"
      },
      "response": {
        "body": {
          "ip": "192.168.1.50",
          "measure": "temperature",
          "sensor": "DS18B20",
          "username": "testuser"
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.2.0"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "MicrocontrollersMS"
  }
}