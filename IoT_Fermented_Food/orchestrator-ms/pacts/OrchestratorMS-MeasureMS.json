{
  "consumer": {
    "name": "OrchestratorMS"
  },
  "interactions": [
    {
      "description": "a request for humidity measurements",
      "providerStates": [
        {
          "name": "measurements exist for user"
        }
      ],
      "request": {
        "headers": {
          "x-internal-api-key": "testkey"
        },
        "method": "GET",
        "path": "/humidity",
        "query": {
          "username": [
            "testuser"
          ]
        }
      },
      "response": {
        "body": [
          {
            "ip": "192.168.1.1",
            "real_value": 45.5,
            "timestamp": 1587855634077,
            "username": "testuser"
          }
        ],
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].ip": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].real_value": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "number"
                }
              ]
            },
            "$[*].timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to save humidity",
      "providerStates": [
        {
          "name": "microcontroller exists"
        }
      ],
      "request": {
        "body": {
          "humidity": 50.5,
          "ip": "192.168.1.1",
          "username": "testuser"
        },
        "headers": {
          "Content-Type": "application/json",
          "x-internal-api-key": "testkey"
        },
        "method": "POST",
        "path": "/humidity"
      },
      "response": {
        "body": {
          "ip": "192.168.1.1",
          "real_value": 50.5,
          "timestamp": 1587855634077,
          "username": "testuser"
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.2.0"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "MeasureMS"
  }
}