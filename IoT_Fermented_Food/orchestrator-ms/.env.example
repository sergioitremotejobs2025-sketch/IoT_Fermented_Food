# orchestrator-ms Environment Variables

# JWT secret for signing/verifying access tokens
# REQUIRED — must match auth-ms JWT_SECRET
JWT_SECRET=your_jwt_secret_here

# auth-ms service hostname and port
AUTH_MS_HOSTNAME=localhost
AUTH_MS_SERVICE_PORT=5000

# measure-ms service hostname and port
MEASURE_MS_HOSTNAME=localhost
MEASURE_MS_SERVICE_PORT=4000

# microcontrollers-ms service hostname and port
MICROCONTROLLERS_MS_HOSTNAME=localhost
MICROCONTROLLERS_MS_SERVICE_PORT=6000

# Shared secret sent to measure-ms in the x-internal-api-key header.
# Must match the INTERNAL_API_KEY env var on the measure-ms side.
# Generate with:  openssl rand -hex 32
INTERNAL_API_KEY=change_me_to_a_strong_random_secret

# Port this service listens on
PORT=3000
