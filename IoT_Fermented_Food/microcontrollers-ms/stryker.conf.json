{
    "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
    "packageManager": "npm",
    "reporters": [
        "html",
        "clear-text",
        "progress"
    ],
    "testRunner": "jest",
    "coverageAnalysis": "perTest",
    "ignoreStatic": true,
    "mutate": [
        "src/**/*.js",
        "!src/index.js"
    ],
    "jest": {
        "projectType": "custom",
        "config": {
            "testEnvironment": "node",
            "collectCoverage": false
        }
    }
}