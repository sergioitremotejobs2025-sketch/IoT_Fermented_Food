# measure-ms Environment Variables

# MongoDB connection
MONGO=localhost:27017
MONGO_DB_NAME=iot_db
MONGO_USERNAME=admin
MONGO_PASSWORD=your_mongo_password_here

# microcontrollers-ms service hostname and port
MICROCONTROLLERS_MS_HOSTNAME=localhost
MICROCONTROLLERS_MS_SERVICE_PORT=6000

# Picture capture interval in hours (default: 10)
PICTURE_INTERVAL_HOURS=10

# Shared secret that orchestrator-ms must send in the x-internal-api-key header.
# Set the same value in INTERNAL_API_KEY on the orchestrator-ms side.
# Generate with:  openssl rand -hex 32
INTERNAL_API_KEY=change_me_to_a_strong_random_secret

# Port this service listens on
PORT=4000
